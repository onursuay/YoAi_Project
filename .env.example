# ─────────────────────────────────────────────────────────────
# YoAi Project — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── A) Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── B) AI Providers ───────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── C) Google / Google Ads ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_PICKER_API_KEY=
GOOGLE_PICKER_CLIENT_ID=
GOOGLE_PICKER_APP_ID=
YOUTUBE_API_KEY=

# ── D) Meta ───────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
# Required: webhook verification token (must match Meta App Dashboard setting)
META_WEBHOOK_VERIFY_TOKEN=
# Required for AES-256-GCM token encryption — minimum 32 characters
META_TOKEN_SECRET=
# Set to false in production; true only for local debugging
META_DEBUG=false

# ── E) YoAlgoritma Safety Flags ───────────────────────────────
# Maximum allowed daily budget per proposal (TRY). Default: 1000
YOAI_MAX_DAILY_BUDGET_TRY=1000
# Multi-AI engine toggle (false until Multi-AI Decision Desk is live)
YOAI_MULTI_AI_ENABLED=false
YOAI_MULTI_AI_TIMEOUT_MS=45000
YOAI_MULTI_AI_MAX_COST_PER_RUN_TRY=
# Direct/active publish flags — keep false until explicitly enabled
YOAI_DIRECT_PUBLISH_ENABLED=false
YOAI_ACTIVE_PUBLISH_ENABLED=false
YOAI_COMPETITOR_INTEL_ENABLED=true
YOAI_DAILY_RUN_ENABLED=true

# ── F) Cron / Security ────────────────────────────────────────
# Required: Vercel Cron authenticates with Authorization: Bearer <CRON_SECRET>
# Set this in Vercel Project Settings → Environment Variables too.
CRON_SECRET=
ADMIN_SECRET=
TURNSTILE_SECRET_KEY=

# ── G) Competitor Intelligence ────────────────────────────────
FIRECRAWL_API_KEY=
GOOGLE_ADS_TRANSPARENCY_KEY=
META_AD_LIBRARY_TOKEN=

# Google Ads Transparency Center via SerpApi (Faz 2B)
# Key yoksa connector disabled — supported:false döner, sahte data üretilmez.
SERPAPI_API_KEY=

# Apify — Sosyal Medya + Rakip İstihbarat Provider
# APIFY_API_TOKEN yoksa tüm social scan'ler public metadata'ya düşer, sahte data üretilmez.
# Token: https://console.apify.com/account/integrations → API tokens
APIFY_API_TOKEN=

# Social kaynak tarama — actor ID'ler Apify console'dan kopyalanır
# apifySocialRunner.ts "/" karakterini otomatik "~" ile değiştirir (Apify URL kuralı)
APIFY_INSTAGRAM_PROFILE_ACTOR_ID=apify/instagram-profile-scraper
APIFY_FACEBOOK_PAGE_ACTOR_ID=apify/facebook-pages-scraper
APIFY_LINKEDIN_COMPANY_ACTOR_ID=curious_coder/linkedin-company-profile-scraper
APIFY_YOUTUBE_CHANNEL_ACTOR_ID=streamers/youtube-channel-scraper
APIFY_TIKTOK_PROFILE_ACTOR_ID=clockworks/tiktok-profile-scraper

# Rakip reklam istihbaratı
APIFY_META_AD_LIBRARY_ACTOR_ID=curious_coder/facebook-ads-library-scraper
APIFY_GOOGLE_ADS_TRANSPARENCY_ACTOR_ID=solidcode/ads-transparency-scraper
COMPETITOR_ADS_PROVIDER=apify
META_AD_LIBRARY_PROVIDER=apify
GOOGLE_ADS_TRANSPARENCY_PROVIDER=apify

# ── H) Payments ───────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# ── I) App / Auth ─────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
